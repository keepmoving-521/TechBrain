# TechBrain local infrastructure environment template.
# Copy this file to infra/local/.env before overriding local ports or passwords.

TECHBRAIN_TIMEZONE=Asia/Shanghai

# MySQL
TECHBRAIN_MYSQL_IMAGE_TAG=8.4
TECHBRAIN_MYSQL_PORT=3306
TECHBRAIN_MYSQL_ROOT_PASSWORD=techbrain_root
TECHBRAIN_MYSQL_DATABASE=techbrain
TECHBRAIN_MYSQL_USER=techbrain
TECHBRAIN_MYSQL_PASSWORD=techbrain

# Redis
TECHBRAIN_REDIS_IMAGE_TAG=7.4-alpine
TECHBRAIN_REDIS_PORT=6379

# ElasticSearch
TECHBRAIN_ELASTICSEARCH_IMAGE_TAG=9.0.0
TECHBRAIN_ELASTICSEARCH_HTTP_PORT=9200
TECHBRAIN_ELASTICSEARCH_TRANSPORT_PORT=9300
TECHBRAIN_ELASTICSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
