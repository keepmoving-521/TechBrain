# Runtime environment: local, test, staging, production
TECHBRAIN_ENVIRONMENT=local

TECHBRAIN_APP_NAME=TechBrain API
TECHBRAIN_APP_VERSION=0.1.0
TECHBRAIN_API_V1_PREFIX=/api/v1
TECHBRAIN_HOST=127.0.0.1
TECHBRAIN_PORT=8000
TECHBRAIN_DEBUG=true

# Logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
TECHBRAIN_LOG_LEVEL=DEBUG
TECHBRAIN_LOG_FORMAT=console

# Database
TECHBRAIN_DATABASE_URL=mysql+pymysql://techbrain:techbrain@127.0.0.1:3306/techbrain?charset=utf8mb4
TECHBRAIN_DATABASE_POOL_SIZE=5
TECHBRAIN_DATABASE_MAX_OVERFLOW=10
TECHBRAIN_DATABASE_POOL_RECYCLE_SECONDS=1800
TECHBRAIN_DATABASE_POOL_PRE_PING=true

# Markdown knowledge repository
# Example: D:\Knowledge\TechBrain or /Users/me/Knowledge/TechBrain
TECHBRAIN_KNOWLEDGE_ROOT=
TECHBRAIN_KNOWLEDGE_FILE_ENCODING=utf-8
TECHBRAIN_KNOWLEDGE_IGNORE_FILE_NAME=.techbrainignore
# Comma-separated extra ignore patterns. Example: private/,*.secret.md
TECHBRAIN_KNOWLEDGE_EXTRA_IGNORE_PATTERNS=
TECHBRAIN_KNOWLEDGE_INCLUDE_DRAFTS=false
TECHBRAIN_KNOWLEDGE_INCLUDE_ARCHIVE=false
TECHBRAIN_KNOWLEDGE_SYNC_BATCH_SIZE=100
TECHBRAIN_KNOWLEDGE_MAX_FILE_SIZE_BYTES=5242880
